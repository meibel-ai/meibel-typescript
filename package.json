{
  "name": "meibel",
  "version": "0.1.0-beta.4",
  "description": "The Meibel API provides document parsing, datasource management, and AI agent orchestration.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/meibel-ai/meibel-typescript.git"
  },
  "homepage": "https://docs.meibel.ai/sdk/typescript",
  "bugs": {
    "url": "https://github.com/meibel-ai/meibel-typescript/issues"
  },
  "license": "MIT",
  "keywords": [
    "meibel",
    "sdk",
    "api",
    "document-parsing",
    "ai"
  ]
}
